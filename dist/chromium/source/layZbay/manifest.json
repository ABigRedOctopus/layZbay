{
  "manifest_version": 3,
  "name": "layZbay",
  "version": "1.2.1",
  "description": "Manifest V3 extension for eBay search, packaged for Chrome, Firefox, Edge, Opera, and Brave.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["contextMenus", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  }
}
