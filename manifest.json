{
  "manifest_version": 3,
  "name": "layZbay",
  "version": "1.1.0",
  "description": "Adds a context menu item to search highlighted text on eBay.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["contextMenus", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  }
}
